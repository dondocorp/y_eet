# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=y_eet
POSTGRES_PASSWORD=y_eet
POSTGRES_DB=y_eet

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
SERVICE_NAME=y_eet-platform-api
SERVICE_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://y_eet:y_eet@postgres:5432/y_eet

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-32-char-minimum-secret-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7
BCRYPT_ROUNDS=12

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# ── Risk ──────────────────────────────────────────────────────────────────────
RISK_EVAL_TIMEOUT_MS=500

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9464

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
