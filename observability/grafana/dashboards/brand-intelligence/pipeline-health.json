{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" },
    { "name": "DS_TEMPO", "label": "Tempo", "type": "datasource", "pluginId": "tempo" }
  ],
  "title": "Brand Intelligence — Pipeline Health",
  "uid": "brand-intel-pipeline",
  "tags": ["brand-intelligence", "social-sentiment", "pipeline", "health"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Up",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 3 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "up{job=\"social-sentiment\"}",
          "legendFormat": "Up"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]
        },
        "mappings": [
          { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
        ]
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Last Pipeline Run (age)",
      "gridPos": { "x": 3, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "time() - social_pipeline_last_run_timestamp",
          "legendFormat": "Seconds since last run"
        }
      ],
      "options": {
        "unit": "s",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 3600 },
            { "color": "red", "value": 7200 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Classifier Failure Rate by Type",
      "gridPos": { "x": 0, "y": 3, "w": 10, "h": 5 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (classifier) (rate(social_classifier_failures_total[1h]))",
          "legendFormat": "{{ classifier }}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Relevance Confidence Distribution",
      "description": "High concentration below 0.4 = noise problem. High at 0.9+ = good brand signal.",
      "gridPos": { "x": 10, "y": 3, "w": 14, "h": 5 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (le) (rate(social_brand_relevance_confidence_bucket_bucket[5m]))",
          "legendFormat": "≤{{ le }}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Posts Collected vs Relevant (denoising ratio)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (platform) (rate(social_posts_collected_total[5m]) * 300)",
          "legendFormat": "collected:{{ platform }}"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum by (platform) (rate(social_posts_relevant_total[5m]) * 300)",
          "legendFormat": "relevant:{{ platform }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Scrape Run Status (last 1h)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (platform) (increase(social_scrape_runs_total[1h]))",
          "legendFormat": "runs:{{ platform }}",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum by (platform) (increase(social_scrape_failures_total[1h]))",
          "legendFormat": "fails:{{ platform }}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 7,
      "type": "traces",
      "title": "Recent Pipeline Traces",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": "Tempo",
          "queryType": "search",
          "filters": [
            { "id": "service-name", "operator": "=", "value": "social-sentiment" }
          ],
          "limit": 20
        }
      ]
    }
  ]
}
