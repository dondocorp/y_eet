{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "Brand Intelligence — Executive View",
  "uid": "brand-intel-exec",
  "tags": ["brand-intelligence", "social-sentiment", "executive"],
  "timezone": "browser",
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "platform",
        "type": "custom",
        "label": "Platform",
        "options": [
          { "text": "All", "value": ".*" },
          { "text": "Reddit", "value": "reddit" },
          { "text": "Twitter", "value": "twitter" }
        ],
        "current": { "text": "All", "value": ".*" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Brand Mentions (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(social_posts_relevant_total{platform=~\"$platform\"}[24h]))",
          "legendFormat": "Relevant Mentions"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Positive Sentiment %",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(social_sentiment_positive_total{platform=~\"$platform\"}[1h])) / (sum(rate(social_sentiment_positive_total{platform=~\"$platform\"}[1h])) + sum(rate(social_sentiment_neutral_total{platform=~\"$platform\"}[1h])) + sum(rate(social_sentiment_negative_total{platform=~\"$platform\"}[1h])) + 0.001)",
          "legendFormat": "Positive %"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 40 },
            { "color": "green", "value": 60 }
          ]
        },
        "unit": "percent",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Negative Sentiment %",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(rate(social_sentiment_negative_total{platform=~\"$platform\"}[1h])) / (sum(rate(social_sentiment_positive_total{platform=~\"$platform\"}[1h])) + sum(rate(social_sentiment_neutral_total{platform=~\"$platform\"}[1h])) + sum(rate(social_sentiment_negative_total{platform=~\"$platform\"}[1h])) + 0.001)",
          "legendFormat": "Negative %"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 30 },
            { "color": "red", "value": 50 }
          ]
        },
        "unit": "percent",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Alerts",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(social_alerts_triggered_total[1h]))",
          "legendFormat": "Alerts (1h)"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 3 }
          ]
        },
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Brand Mention Volume — Last 24h",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (platform) (rate(social_posts_relevant_total{platform=~\"$platform\"}[1h]) * 3600)",
          "legendFormat": "{{ platform }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "displayName": "Mentions/hour" },
        "custom": { "lineWidth": 2, "fillOpacity": 10 }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sentiment Trend — Last 24h",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(social_sentiment_positive_total{platform=~\"$platform\"}[1h]) * 3600",
          "legendFormat": "Positive"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(social_sentiment_neutral_total{platform=~\"$platform\"}[1h]) * 3600",
          "legendFormat": "Neutral"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(social_sentiment_negative_total{platform=~\"$platform\"}[1h]) * 3600",
          "legendFormat": "Negative"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Positive" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Neutral" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "Negative" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Sentiment Distribution (24h)",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(social_sentiment_positive_total{platform=~\"$platform\"}[24h]))",
          "legendFormat": "Positive"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(social_sentiment_neutral_total{platform=~\"$platform\"}[24h]))",
          "legendFormat": "Neutral"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(social_sentiment_negative_total{platform=~\"$platform\"}[24h]))",
          "legendFormat": "Negative"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Alert History (7d)",
      "gridPos": { "x": 8, "y": 12, "w": 16, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (alert_name) (increase(social_alerts_triggered_total[1h]))",
          "legendFormat": "{{ alert_name }}"
        }
      ]
    }
  ]
}
