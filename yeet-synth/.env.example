# ── Target ────────────────────────────────────────────────────────────────────
SYNTH_BASE_URL=http://localhost:8080
SYNTH_INTERNAL_URL=http://localhost:8080

# ── Identity ──────────────────────────────────────────────────────────────────
SYNTH_SERVICE_NAME=yeet-synth
SYNTH_ENVIRONMENT=local

# ── Observability ─────────────────────────────────────────────────────────────
SYNTH_OTEL_ENDPOINT=http://localhost:4317
# Standard OTel env var also accepted:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4317

# ── Behaviour ─────────────────────────────────────────────────────────────────
SYNTH_LOG_LEVEL=INFO
SYNTH_TLS_VERIFY=true
SYNTH_TOKEN_POOL_SIZE=20

# ── Reporting ─────────────────────────────────────────────────────────────────
SYNTH_JSON_REPORT=report.json

# ── Config file ───────────────────────────────────────────────────────────────
SYNTH_CONFIG=config/default.yaml
