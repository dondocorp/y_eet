# ── Brand / Query ─────────────────────────────────────────────────────────────
BRAND_QUERIES=yeet casino,yeet.com,yeetcasino
TARGET_BRAND_PRIMARY=yeet casino

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=/app/data

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_ENABLED_PLATFORMS=reddit,twitter
SCRAPER_MAX_POSTS_PER_RUN=100
SCRAPER_PAGE_TIMEOUT_MS=30000
SCRAPER_RATE_LIMIT_DELAY_S=2.0
SCRAPER_MAX_RETRIES=3
SCRAPER_HEADLESS=true

# ── NLP ───────────────────────────────────────────────────────────────────────
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
RELEVANCE_EMBEDDING_ENABLED=false
RELEVANCE_EMBEDDING_THRESHOLD=0.6
CLASSIFIER_BATCH_SIZE=32
MODEL_CACHE_DIR=/app/model_cache

# ── Metrics ───────────────────────────────────────────────────────────────────
METRICS_PORT=9465
METRICS_PATH=/metrics

# ── Alerting ──────────────────────────────────────────────────────────────────
ALERT_BACKEND=telegram

# Telegram — get token from @BotFather, chat_id from @userinfobot or API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alertmanager — matches existing docker-compose service
ALERTMANAGER_WEBHOOK_URL=http://alertmanager:9093/api/v2/alerts

ALERT_NEG_RATIO_THRESHOLD=0.40
ALERT_NEG_RATIO_WINDOW_HOURS=1
ALERT_MENTION_SPIKE_MULTIPLIER=3.0
ALERT_SCAM_COUNT_THRESHOLD=5
ALERT_SUPPRESSION_MINUTES=60

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=social-sentiment
OTEL_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_INTERVAL_MINUTES=30
